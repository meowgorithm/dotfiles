{
  "$schema": "https://charm.land/crush.json",
  "options": {
    "progress": false
  },
  "mcp": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "$(echo Bearer $GITHUB_TOKEN)"
      }
    },
    "linear": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.linear.app/mcp"
      ]
    },
    "ceramic": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.ceramic.ai/mcp"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^bash$",
        "command": "~/.config/crush/hooks/rtk-rewrite.sh"
      }
    ]
  },
  "permissions": {
    "allowed_tools": []
  }
}